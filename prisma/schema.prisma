generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  passwordHash String
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  username     String   @unique
  shop         Shop?
}

model RegistrationInterest {
  id        String   @id @default(uuid())
  username  String
  password  String // Hashed
  shopName  String
  phone     String
  status    String   @default("pending") // pending, approved, rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shop {
  id               String              @id @default(uuid())
  ownerId          String              @unique
  shopName         String
  phone            String
  status           String              @default("active")
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  automations      Automation[]
  campaigns        Campaign[]
  contacts         Contact[]
  conversations    Conversation[]
  mediaFiles       MediaFile[]
  messages         Message[]
  owner            User                @relation(fields: [ownerId], references: [id])
  subscription     Subscription?
  templates        Template[]
  whatsappAccounts WhatsAppBusinessAccount[]
  phoneNumbers     WhatsAppPhoneNumber[]
  onboardingEvents OnboardingEvent[]
  chatbotConfig    ChatbotConfig?
  flows            Flow[]
}

model Subscription {
  id         String   @id @default(uuid())
  shopId     String   @unique
  startDate  DateTime
  expiryDate DateTime
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  shop       Shop     @relation(fields: [shopId], references: [id])
}

model WhatsAppBusinessAccount {
  id                 String   @id @default(uuid())
  shopId             String
  businessAccountId  String
  wabaId             String?
  businessName       String?
  accessToken        String
  tokenType          String   @default("long_lived")
  tokenExpiry        DateTime?
  webhookVerifyToken String?
  status             String   @default("active") // active, disconnected, suspended, token_expired
  onboardingSource   String   @default("manual") // manual, embedded_signup
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  shop               Shop     @relation(fields: [shopId], references: [id])
  phoneNumbers       WhatsAppPhoneNumber[]

  @@index([shopId])
  @@index([businessAccountId])
  @@index([wabaId])
}

model WhatsAppPhoneNumber {
  id                 String   @id @default(uuid())
  shopId             String
  wabaAccountId      String
  phoneNumberId      String   @unique
  displayPhoneNumber String?
  verifiedName       String?
  qualityRating      String?
  messagingLimit     String?
  status             String   @default("active")
  isDefault          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  shop               Shop     @relation(fields: [shopId], references: [id])
  wabaAccount        WhatsAppBusinessAccount @relation(fields: [wabaAccountId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([phoneNumberId])
}

model WebhookAuditLog {
  id               String   @id @default(uuid())
  shopId           String?
  phoneNumberId    String?
  eventType        String
  waMessageId      String?
  payload          Json
  processingStatus String   @default("pending")
  errorMessage     String?
  retryCount       Int      @default(0)
  createdAt        DateTime @default(now())

  @@index([shopId])
  @@index([phoneNumberId])
  @@index([processingStatus])
  @@index([createdAt])
}

model DeadLetterEvent {
  id              String    @id @default(uuid())
  sourceType      String
  originalPayload Json
  errorMessage    String?
  retryCount      Int       @default(0)
  maxRetries      Int       @default(3)
  lastAttemptAt   DateTime?
  resolvedAt      DateTime?
  status          String    @default("pending")
  createdAt       DateTime  @default(now())

  @@index([status])
  @@index([sourceType])
}

model OnboardingEvent {
  id        String   @id @default(uuid())
  shopId    String
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())
  shop      Shop     @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([eventType])
}

model Contact {
  id               String            @id @default(uuid())
  shopId           String
  name             String
  phone            String
  tags             Json?
  city             String?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  shop             Shop              @relation(fields: [shopId], references: [id])
  conversations    Conversation[]
  campaignContacts CampaignContact[]
  flowSession      FlowSession?

  @@unique([shopId, phone])
}

model Conversation {
  id            String    @id @default(uuid())
  shopId        String
  contactId     String
  phoneNumberId String?
  lastMessageAt DateTime  @default(now())
  unreadCount   Int       @default(0)
  aiPaused      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  contact       Contact   @relation(fields: [contactId], references: [id])
  shop          Shop      @relation(fields: [shopId], references: [id])
  messages      Message[]

  @@unique([shopId, contactId])
}

model Message {
  id             String       @id @default(uuid())
  shopId         String
  conversationId String
  phoneNumberId  String?
  direction      String
  type           String
  content        String?
  mediaUrl       String?
  templateData   Json?
  status         String       @default("sent")
  timestamp      DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  shop           Shop         @relation(fields: [shopId], references: [id])
}

model Template {
  id           String     @id @default(uuid())
  shopId       String
  templateName String
  category     String
  language     String
  components   Json
  status       String     @default("pending")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  campaigns    Campaign[]
  shop         Shop       @relation(fields: [shopId], references: [id])
}

model Campaign {
  id             String            @id @default(uuid())
  shopId         String
  name           String
  templateId     String
  targetTags     Json?
  targetPhones   Json?
  templateParams Json?
  headerMediaUrl String?
  status         String            @default("scheduled")
  scheduledAt    DateTime
  stats          Json?
  failureHistory Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  shop           Shop              @relation(fields: [shopId], references: [id])
  template       Template          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  contacts       CampaignContact[]
}

model CampaignContact {
  id         String   @id @default(uuid())
  campaignId String
  contactId  String?
  phone      String
  name       String
  wamid      String?
  status     String   @default("pending")
  failReason String?
  sentAt     DateTime @default(now())
  updatedAt  DateTime @updatedAt
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact    Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([campaignId, phone])
}

model MediaFile {
  id        String   @id @default(uuid())
  shopId    String
  fileName  String?
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())
  shop      Shop     @relation(fields: [shopId], references: [id])
}

model Automation {
  id             String   @id @default(uuid())
  shopId         String
  type           String
  triggerKeyword String?
  replyText      String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  shop           Shop     @relation(fields: [shopId], references: [id])
}

model ChatbotConfig {
  id           String   @id @default(uuid())
  shopId       String   @unique
  isActive     Boolean  @default(false)
  apiKey       String?
  model        String   @default("gemini-1.5-flash")
  temperature  Float    @default(0.7)
  systemPrompt String?  @db.Text
  businessInfo String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  shop         Shop     @relation(fields: [shopId], references: [id])
}

model Flow {
  id             String          @id @default(uuid())
  shopId         String
  name           String
  description    String?
  category       String          @default("Custom")
  status         String          @default("Draft")
  nodeCount      Int             @default(0)
  nodes          Json?
  edges          Json?
  triggerKeyword String?
  isDefault      Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  shop           Shop            @relation(fields: [shopId], references: [id])
  analytics      FlowAnalytics[]
  versions       FlowVersion[]
  sessions       FlowSession[]
}

model FlowSession {
  id            String   @id @default(uuid())
  contactId     String   @unique
  flowId        String
  currentNodeId String?
  variables     Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  contact       Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  flow          Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
}

model FlowAnalytics {
  id        String   @id @default(uuid())
  flowId    String
  nodeId    String
  hits      Int      @default(0)
  updatedAt DateTime @updatedAt
  flow      Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@unique([flowId, nodeId])
}

model FlowVersion {
  id            String   @id @default(uuid())
  flowId        String
  versionNumber Int
  name          String
  nodes         Json?
  edges         Json?
  createdAt     DateTime @default(now())
  flow          Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
}
